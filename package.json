{
  "name": "propiedades-el-31-facturacion",
  "version": "0.3.0",
  "private": true,
  "description": "Aplicación de escritorio offline para facturación de Propiedades El 31",
  "homepage": "https://propiedadesel31.com.ar",
  "author": {
    "name": "Propiedades El 31",
    "email": "contacto@propiedadesel31.com.ar"
  },
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json --watch & wait-on tcp:5173 && electron .",
    "build": "npm run build:renderer && npm run build:electron && npm run build:server",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:server": "tsc -p tsconfig.server.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "dist": "npm run build && electron-builder --win --x64",
    "dist:linux": "npm run build && electron-builder --linux --x64",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.7.0",
    "csv-parse": "^5.6.0",
    "electron-updater": "^6.3.9",
    "exceljs": "^4.4.0",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "kysely": "^0.27.5",
    "pdfkit": "^0.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@mui/icons-material": "^6.1.10",
    "@mui/material": "^6.1.10",
    "@mui/x-data-grid": "^7.23.2",
    "@mui/x-date-pickers": "^7.23.2",
    "@tanstack/react-query": "^5.62.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.1",
    "@types/pdfkit": "^0.13.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.0",
    "react-router-dom": "^6.28.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
